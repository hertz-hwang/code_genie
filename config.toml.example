# =========================================================================
# 🔧 CodeGenie 配置文件
# =========================================================================
# 使用方法：将本文件复制为 config.toml，按需修改后运行优化。
# 运行命令：cargo run --release -- -c config.toml

# -------------------------------------------------------------------------
# 📂 文件路径配置
# -------------------------------------------------------------------------
[files]
# 固定字根文件：每行格式为 "字根名\t键位"
#   - 单个键位 → 固定字根，直接绑定该键，不参与优化
#   - 多个键位（空格分隔）→ 有约束字根，优化时只能从这些键中选一个
fixed = "input-fixed.txt"

# 动态字根文件：每行为一组字根（空格分隔），同组字根共享同一键位
#   优化器会为每组选择最优键位，是优化的主要对象
dynamic = "input-roots.txt"

# 拆分表文件：每行格式为 "汉字\t字根1 字根2 ...\t频率"
#   定义每个汉字由哪些字根组成，以及该汉字在语料中的使用频率
splits = "input-division.txt"

# 字根对当量文件：每行格式为 "键对\t当量值"
#   记录两个键连续击打的手指移动代价（当量越小越流畅）
#   与 --keysoul 参数互斥：使用 --keysoul 时忽略此文件，改用物理模型计算
pair_equiv = "pair_equivalence.txt"

# 用指分布文件：每行格式为 "键位\t目标%\t低惩罚\t高惩罚"
#   定义每个键位的理想使用频率及偏离惩罚，用于优化键位负载均衡
key_dist = "key_distribution.txt"

# -------------------------------------------------------------------------
# 🎰 AMHB 算法参数（仅 --amhb 模式使用）
# -------------------------------------------------------------------------
# AMHB（Adaptive Multi-candidate Heat Bath）是模拟退火的替代算法。
# 核心思想：用 EXP3 多臂老虎机自适应选择算子，温度固定（Heat Bath 准则），
# 不使用退火调度。适合探索性更强的搜索场景。
[amhb]
# EXP3 算子池大小：同时维护的候选邻居解数量。
#   值越大，每步探索范围越广，但内存和计算开销也越大。
total_neighbors = 200

# 工作窃取阈值：当某线程的任务队列剩余量低于此值时，
#   允许从其他线程"窃取"任务，提高多线程负载均衡效率。
steal_threshold = 0

# 最大迭代步数：AMHB 算法的总运行步数上限，达到后强制停止。
total_steps = 1000000000

# AMHB 初始温度：Heat Bath 接受准则中的温度参数。
#   温度越高，接受劣解的概率越大（探索性越强）；
temp_start = 100.0

# 分段降温参数（piecewise exponential cooling）
# 每段定义 threshold 和 factor：当 temp > threshold 时，每步 temp *= factor
# 按 threshold 从高到低排列，第一个满足的段生效
# 若温度低于所有阈值，优化终止
[[amhb.cooling_segments]]
# 高温区（temp > 7.5）：快速降温，快速跳出初始随机状态
threshold = 7.5
factor = 0.99999

[[amhb.cooling_segments]]
# 中高温区（1.75 < temp ≤ 7.5）：适中降温，平衡探索与利用
threshold = 1.75
factor = 0.999999

[[amhb.cooling_segments]]
# 中低温区（1.25 < temp ≤ 1.75）：缓慢降温，精细搜索
threshold = 1.25
factor = 0.9999995

[[amhb.cooling_segments]]
# 低温区（0.15 < temp ≤ 1.25）：极缓慢降温，收敛到局部最优
#   当 temp ≤ 0.000001 时，所有段均不满足，算法终止
threshold = 0.000001
factor = 0.9999999625

# -------------------------------------------------------------------------
# 🌡️ 模拟退火参数（默认优化模式使用）
# -------------------------------------------------------------------------
[annealing]
# 并行线程数：同时运行的独立 SA 实例数量。
#   每个线程从不同初始解出发，最终取所有线程中的最优结果。
#   建议设为 CPU 核心数，过多会因上下文切换降低效率。
threads = 8

# 总迭代步数：每个线程执行的 SA 步数上限。
#   步数越多，优化质量越高，但耗时也越长。
#   实际运行时间 ≈ total_steps / (速度 万步/分钟)。
total_steps = 2000000

# 初始温度：SA 开始时的温度，决定初期接受劣解的概率。
#   温度越高，初期探索范围越广；过高会导致随机游走，过低会过早收敛。
temp_start = 100.0

# 结束温度：SA 终止的温度阈值，低于此值时停止。
#   通常设为极小值，确保算法在 total_steps 内自然结束。
temp_end = 0.000001

# 舒适温度（高斯中心）：降温曲线在此温度附近会自动减速。
#   模拟"舒适区"效应：在最有可能找到好解的温度范围内多花时间。
#   通常设为略高于最终收敛温度的值。
comfort_temp = 0.4

# 舒适区宽度（高斯 sigma）：舒适区的温度范围半径。
#   值越大，减速效果覆盖的温度范围越宽；值越小，减速越集中。
comfort_width = 0.15

# 舒适区减速因子（0~1）：在舒适区内降温速率乘以此因子。
#   0.7 表示降温速度降至正常的 70%，即在舒适区多停留约 43% 的时间。
#   设为 1.0 可禁用舒适区减速。
comfort_slowdown = 0.7

# 交换操作概率（0~1）：每步选择 swap（交换两组键位）的概率。
#   剩余概率 (1 - swap_probability) 执行 move（将一组移到新键位）。
#   swap 保持键位集合不变，适合精细调整；move 改变键位集合，探索性更强。
#   此概率会随迭代进度线性增长，后期更多使用 swap。
swap_probability = 0.35

# 以下参数基于 total_steps 的比例计算
# 最小改进步数比例：连续经过 (total_steps * ratio) 步无改进时触发重热。
#   0.1 表示连续 20 万步（200000 步）无改进则重热。
#   设为较大值可减少重热频率，让 SA 在当前区域充分搜索。
min_improve_steps_ratio = 0.1

# 扰动间隔比例：每隔 (total_steps * ratio) 步执行一次低温扰动。
#   设为 0 可完全关闭扰动机制（推荐：扰动效果因问题而异）。
perturb_interval_ratio = 0.0

# 扰动强度：扰动时随机移动的字根组数量比例。
#   0 表示不扰动；较大值会大幅改变当前解，有助于跳出深层局部最优。
perturb_strength = 0.0

# 扰动触发温度比例：当 base_temp < comfort_temp * ratio 时才允许扰动。
#   确保扰动只在低温（接近收敛）时发生，避免高温期无效扰动。
perturb_trigger_temp_ratio = 0.01

# 扰动时温度倍率：扰动发生时将当前温度乘以此值，临时升温以接受扰动后的解。
#   2.0 表示扰动后温度翻倍，增加接受新解的概率。
perturb_temp_multiplier = 2.0

# 扰动时优先采样的冲突对上限：扰动时优先选择参与重码的字根组进行移动。
#   10 表示最多从 10 个冲突对中采样，聚焦于解决当前重码问题。
perturb_collision_pairs_limit = 10

# 重热倍率：触发重热时将当前温度乘以此值。
#   1.0 表示不重热（禁用重热机制）；
#   大于 1.0（如 1.5）表示重热时温度升高 50%，帮助跳出局部最优。
reheat_factor = 1.0

# 最大码长：汉字编码的最大字根数（即最多取几个字根的键位组成编码）。
#   3 表示最多取前 3 个字根，超出部分忽略。
#   应与输入法方案的码长设计一致。
max_parts = 3

# -------------------------------------------------------------------------
# ⌨️ 键位配置
# -------------------------------------------------------------------------
[keys]
# 允许的键位字符：动态字根可以分配到的键位集合。
#   通常为 26 个英文字母；可以去掉某些键（如 z）来保留特殊用途。
allowed = "qwertyuiopasdfghjklzxcvbnm"

# 键位显示顺序：输出报告（键位分布统计）中键位的排列顺序。
#   按此顺序显示每个键的使用率，方便对照键盘布局阅读。
display_order = "qwertyuiopasdfghjklzxcvbnm"

# -------------------------------------------------------------------------
# ⚖️ 权重配置
# -------------------------------------------------------------------------
# 优化目标 = 全码目标 * full_code_weight + 简码目标 * simple_code_weight
# 全码目标 = Σ(各指标值 * 对应权重)，权重总和建议为 1.0

[weights.full_code]
# 全码重码数权重：重码数越少越好。
#   重码数 = 编码相同的汉字对数，直接影响输入时需要翻页选字的频率。
#   这是最核心的优化目标，通常给予最高权重。
collision_count = 1.0

# 全码重码率权重：重码率 = 重码字的加权频率占比。
#   与重码数互补：重码率更关注高频字的重码情况。
#   设为 0 时只优化重码数，不区分高频低频重码。
collision_rate = 0.0

# 当量权重：所有汉字编码的平均击键当量（手指移动代价）。
#   当量越小，输入越流畅；需要 pair_equivalence.txt 或 --keysoul 提供当量数据。
equivalence = 0.0

# 当量变异系数权重：当量的标准差/均值，衡量当量分布的均匀程度。
#   CV 越小，各汉字的输入流畅度越一致，避免部分字极难输入。
equiv_cv = 0.0

# 分布偏差权重：实际键位使用率与 key_distribution.txt 中目标分布的偏差。
#   偏差越小，手指负载越均衡，长期使用不易疲劳。
distribution = 0.0

[weights.simple_code]
# 是否启用简码优化：true 时同时优化全码和简码目标。
#   简码（一级简码、二级简码等）让高频字可以用更少按键输入。
#   启用后优化时间会增加，但能显著提升高频字的输入效率。
enabled = false

# 全码目标总权重：在联合优化中，全码目标占总目标的比重。
#   full_code_weight + simple_code_weight 建议等于 1.0。
full_code_weight = 1.0

# 简码目标总权重：简码目标在总目标中的比重。
#   值越大，优化器越倾向于改善简码质量，可能以牺牲部分全码质量为代价。
simple_code_weight = 0.0

# 简码内部子权重（总和建议为 1.0，仅 enabled=true 时生效）

# 简码重码数权重：简码中编码相同的汉字对数。
collision_count = 0.0

# 简码重码率权重：简码重码的加权频率占比。
collision_rate = 0.0

# 频率覆盖权重：被分配到简码的汉字频率总和占比。
#   覆盖率越高，越多的高频字能享受简码加速。
freq = 0.0

# 简码当量权重：简码编码的平均击键当量。
equiv = 0.0

# 简码分布偏差权重：简码键位使用率与目标分布的偏差。
dist = 0.0

# -------------------------------------------------------------------------
# 📝 简码规则配置
# -------------------------------------------------------------------------
# 取码规则说明:
#   每两个字符为一组，第一个字符选择逻辑根，第二个字符选择该根的码位
#   根选择: A=第1根, B=第2根, C=第3根, ... Z=最后一根
#   码位选择: a=第1码, b=第2码, c=第3码, ... z=最后一码
#
# 示例: 全码为4码定长方案，拆分 "在 𠂇 𠂇.1 2 土 土.1"
#   逻辑根: [𠂇(码=[𠂇,𠂇.1]), 2(码=[2]), 土(码=[土,土.1])]
#   Aa = 𠂇的第1码, Ab = 𠂇的第2码
#   Ba = 2的第1码
#   Ca = 土的第1码, Cz = 土的最后一码
#   Za = 最后一根(土)的第1码, Zz = 最后一根(土)的最后一码

# 一级简码：只用 1 个键表示一个汉字（最短简码）
#   level=1 表示一级简码
#   code_num=0 表示不限制数量，按频率贪心分配（尽量多分配）
#     若设为正整数 N，则只分配频率最高的 N 个汉字
#   rules=["Aa"] 表示取第1逻辑根的第1个码位作为简码
[[simple_levels]]
level = 1
code_num = 0
rules = ["Aa"]

# 二级简码：用 2 个键表示一个汉字
#   rules=["AaBa"] 表示取第1根第1码 + 第2根第1码
[[simple_levels]]
level = 2
code_num = 0
rules = ["AaBa"]

# 三级简码：用 3 个键表示一个汉字
#   rules 支持多个候选规则，系统依次尝试，选择第一个能成功解析的规则
#   "AaAbZz" = 第1根第1码 + 第1根第2码 + 最后一根最后一码（适合多码根方案）
#   "AaBaZz" = 第1根第1码 + 第2根第1码 + 最后一根最后一码（适合单码根方案）
[[simple_levels]]
level = 3
code_num = 0
rules = ["AaAbZz", "AaBaZz"]
