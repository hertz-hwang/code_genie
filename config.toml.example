# =========================================================================
# 🔧 CodeGenie 配置文件
# =========================================================================

# -------------------------------------------------------------------------
# 📂 文件路径配置
# -------------------------------------------------------------------------
[files]
fixed = "input-fixed.txt"        # 固定字根文件
dynamic = "input-roots.txt"      # 动态字根文件
splits = "input-division.txt"    # 拆分表文件
pair_equiv = "pair_equivalence.txt"  # 字根对当量文件
key_dist = "key_distribution.txt"    # 用指分布文件

# -------------------------------------------------------------------------
# 🌡️ 模拟退火参数
# -------------------------------------------------------------------------
[annealing]
threads = 12             # 并行线程数
total_steps = 2000000     # 总迭代步数
temp_start = 100.0         # 初始温度
temp_end = 0.000001      # 结束温度
comfort_temp = 0.4       # 舒适温度区间
comfort_width = 0.15     # 舒适区宽度
comfort_slowdown = 0.7   # 舒适区减速因子
swap_probability = 0.35   # 交换操作概率

# 以下参数基于 total_steps 的比例计算
min_improve_steps_ratio = 0.1    # 最小改进步数比例 (total_steps / 10)
perturb_interval_ratio = 0.0    # 设为 0 可关闭低温扰动
perturb_strength = 0.0          # 扰动强度
perturb_trigger_temp_ratio = 0.01 # 扰动触发温度比例 (base_temp < comfort_temp * ratio)
perturb_temp_multiplier = 2.0     # 扰动时温度倍率 (temp * multiplier)
perturb_collision_pairs_limit = 10 # 扰动时优先采样的冲突对上限
reheat_factor = 1.0             # 设为 1.0 可关闭重新加热
max_parts = 3                    # 最大码长

# -------------------------------------------------------------------------
# ⌨️ 键位配置
# -------------------------------------------------------------------------
[keys]
# 允许的键位字符（用于动态字根分配）
allowed = "qwertyuiopasdfghjklzxcvbnm"
# 键位显示顺序（用于输出报告）
display_order = "qwertyuiopasdfghjklzxcvbnm"

# -------------------------------------------------------------------------
# ⚖️ 权重配置
# -------------------------------------------------------------------------
[weights.full_code]
# 全码部分权重（总和应为 1.0）
collision_count = 0.19    # 重码数权重
collision_rate = 0.3     # 重码率权重
equivalence = 0.3        # 当量权重
equiv_cv = 0.01           # 当量变异系数权重
distribution = 0.2       # 分布偏差权重

[weights.simple_code]
# 简码优化开关与权重
enabled = true           # 是否启用简码优化
full_code_weight = 0.6   # 全码目标总权重
simple_code_weight = 0.4 # 简码目标总权重

# 简码内部子权重（总和应为 1.0）
collision_count = 0.1    # 重码数权重
collision_rate = 0.3     # 重码率权重
freq = 0.2               # 频率覆盖权重
equiv = 0.2              # 当量权重
dist = 0.2               # 分布偏差权重

# -------------------------------------------------------------------------
# 📝 简码规则配置
# -------------------------------------------------------------------------
# 取码规则说明:
#   每两个字符为一组，第一个字符选择逻辑根，第二个字符选择该根的码位
#   根选择: A=第1根, B=第2根, C=第3根, ... Z=最后一根
#   码位选择: a=第1码, b=第2码, c=第3码, ... z=最后一码
#
# 示例: 全码为4码定长方案，拆分 "在 𠂇 𠂇.1 2 土 土.1"
#   逻辑根: [𠂇(码=[𠂇,𠂇.1]), 2(码=[2]), 土(码=[土,土.1])]
#   Aa = 𠂇的第1码, Ab = 𠂇的第2码
#   Ba = 2的第1码
#   Ca = 土的第1码, Cz = 土的最后一码
#   Za = 最后一根(土)的第1码, Zz = 最后一根(土)的最后一码

[[simple_levels]]
level = 1
code_num = 1
rules = ["Aa"]

[[simple_levels]]
level = 2
code_num = 1
rules = ["AaBa"]

[[simple_levels]]
level = 3
code_num = 0
rules = ["AaAbZz", "AaBaZz"]
